# 复制本文件为 `.env` 并按需填写。
# 注意：当前仓库的 `main.py` / `structures.py` 默认不读取 `.env`。
# 若要用环境变量覆盖配置，可在入口增加 `python-dotenv` 的 `load_dotenv()` 后自行读取 `os.environ`。

# ---------- 运行环境 ----------
# 无图形界面时 Matplotlib 后端（也可在命令行临时设置）
# MPLBACKEND=Agg

# ---------- 网络（AkShare 依赖 requests；部分网络环境需要代理）----------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ---------- 预留：大模型 / 新闻观点（若你后续接入）----------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# ---------- 预留：与 structures 对齐的覆盖（需你在代码里读取）----------
# 数据源（与 structures.DATA_SOURCE 一致）: akshare | json | csv | baostock | tushare
# BL_DATA_SOURCE=akshare
# 主源失败后的顺序（与 structures.DATA_SOURCE_FALLBACK 一致；空则禁用自动切换）
# BL_DATA_SOURCE_FALLBACK=baostock,tushare,csv,json
# TUSHARE_TOKEN=   # DATA_SOURCE=tushare 时必填（https://tushare.pro）
# BL_AKSHARE_START_DATE=2020-01-01
# BL_AKSHARE_END_DATE=2025-12-31
# BL_BACK_TEST_YEAR=2025
