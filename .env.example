# 复制本文件为 `.env` 并按需填写。
# 注意：当前仓库的 `code/main.py` / `code/structures.py` 默认不读取 `.env`。
# 若要用环境变量覆盖配置，可在入口增加 `python-dotenv` 的 `load_dotenv()` 后自行读取 `os.environ`。

# ---------- 运行环境 ----------
# 无图形界面时 Matplotlib 后端（也可在命令行临时设置）
# MPLBACKEND=Agg

# ---------- 网络（AkShare 依赖 requests；部分网络环境需要代理）----------
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ---------- 预留：大模型 / 新闻观点（通用）----------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# ANTHROPIC_API_KEY=

# ---------- 预留：与 structures 对齐的覆盖（需你在代码里读取）----------
# 数据源（与 structures.DATA_SOURCE 一致）: akshare | json | csv | baostock | tushare
# BL_DATA_SOURCE=akshare
# 主源失败后的顺序（与 structures.DATA_SOURCE_FALLBACK 一致；空列表=仅用主源、不自动切换；仓库默认 AkShare 且不回退）
# BL_DATA_SOURCE_FALLBACK=
# TUSHARE_TOKEN=   # DATA_SOURCE=tushare 时必填（https://tushare.pro）
# BL_AKSHARE_START_DATE=2020-01-01
# BL_AKSHARE_END_DATE=2025-12-31
# BL_BACK_TEST_YEAR=2025

# =============================================================================
# 情绪量化 Agent（`run_api.py`、`emotion_bl/`；默认通过 pydantic-settings 读 `.env`）
# =============================================================================
# 启动：`./restart_server.sh`（或 `python run_api.py`）
#
# SENTIMENT_BACKEND=llm
# 标的映射：keyword_map=关键词表（默认）；llm_json=由 LLM 从每条新闻 JSON 里输出 tickers（须与 llm 同开）
# TICKER_MAPPING_MODE=llm_json
# LLM_TICKER_JSON_FALLBACK_KEYWORD=true
# LLM_API_KEY=sk-请填写你的百炼密钥
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-turbo-latest
# 单条新闻单次 HTTP 读超时（秒）
# LLM_PER_ARTICLE_READ_SEC=60
# 读超时后的额外重试次数（不含首次）
# LLM_PER_ARTICLE_MAX_RETRIES=3
# LLM 情感并发数（仅 llm 模式）
# LLM_MAX_CONCURRENT=8
# 单次「运行分析」整流程墙钟上限（秒）；0 = 不限制
# ANALYSIS_DEADLINE_SEC=0
# LLM_DASHSCOPE_REGION=cn
# NEWS_JSONL_PATH=data/news_items.jsonl
# API_HOST=0.0.0.0
# API_PORT=8000

# ---------- Istero 开放数据（央视国内要闻 latest）----------
# 周频全流程（`/pipeline-full`、`run_weekly_blm_agent.py`）默认用此 API 采集中文新闻；无 Token 时请改用「跳过采集」或 `--news-source rss`。
# 开发者中心获取 Token；请求头 Authorization: Bearer <token>
# ISTERO_API_TOKEN=
# 可选：覆盖接口 URL
# ISTERO_API_URL=https://api.istero.com/resource/v1/cctv/china/latest/news
# 若服务商强制动态签名，需按其《开发文档》实现 X-Signature 后再启用：
# ISTERO_USE_SIGNATURE_HEADERS=false
# ISTERO_SIGN_SECRET=
# 拉取落盘：.venv/bin/python scripts/fetch_istero_cctv_news.py --append
